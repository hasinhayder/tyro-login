{
    "name": "hasinhayder/tyro-login",
    "description": "Tyro Login - Beautiful, customizable authentication views for Laravel 12 & 13",
    "keywords": [
        "laravel",
        "authentication",
        "login",
        "register",
        "auth",
        "blade",
        "ui",
        "socialite",
        "oauth"
    ],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/view": "^12.0 || ^13.0",
        "illuminate/routing": "^12.0 || ^13.0",
        "illuminate/auth": "^12.0 || ^13.0",
        "illuminate/session": "^12.0 || ^13.0",
        "bacon/bacon-qr-code": "^3.0",
        "pragmarx/google2fa": "^9.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0 || ^11.0",
        "laravel/pint": "^1.27",
        "nunomaduro/collision": "^8.6 || ^9.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "suggest": {
        "laravel/socialite": "^5.0 || ^6.0"
    },
    "autoload": {
        "psr-4": {
            "HasinHayder\\TyroLogin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HasinHayder\\TyroLogin\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest"
    },
    "extra": {
        "laravel": {
            "providers": [
                "HasinHayder\\TyroLogin\\Providers\\TyroLoginServiceProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "2.4.x-dev"
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}